APP_NAME=auth
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8080

# Database drivers: mysql, postgre and sqlite.
DB_DRIVER=mysql
DB_HOST=mysql_auth
DB_PORT=3306
# For SQLite, DB_DATABASE must be the route of the database (ej: storage/database.sqlite).
DB_DATABASE=auth
DB_USERNAME=auth
DB_PASSWORD=auth
DB_LOCAL_MAX_IDLE_CONNECTIONS=10
DB_LOCAL_MAX_OPEN_CONNECTIONS=100

#Log driver options: stdout and file.
LOG_DRIVER=stdout
LOG_PATH=logs/auth.log
#Log level: debug, info, warn and error.
LOG_LEVEL=debug

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=auth
REDIS_DATABASE=0

# Auth
AUTH_JWT_SECRET=secret

# All expiries are in minutes.
AUTH_ACCESS_TOKEN_EXPIRE=15
AUTH_REFRESH_TOKEN_EXPIRE=10080
AUTH_EMAIL_VERIFICATION_EXPIRE=60

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest